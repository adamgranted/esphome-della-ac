# Copy to secrets.yaml (next to della-slwf.yaml) and fill in.
# secrets.yaml is gitignored — never commit real values.
wifi_ssid: "your-wifi-ssid"
wifi_password: "your-wifi-password"
api_encryption_key: "generate with: openssl rand -base64 32"
ota_password: "pick-a-strong-password"
fallback_ap_password: "pick-a-strong-password"
